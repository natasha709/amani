{
  "name": "amani-backend",
  "version": "1.0.0",
  "description": "Amani School System Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "migrate": "prisma migrate dev",
